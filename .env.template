# API Keys (same as before, works for both USDT-M and USDS-M)
BINANCE_API_KEY=your-api-key-here-min-30-chars
BINANCE_API_SECRET=your-api-secret-here-min-30-chars

# Network Selection
BINANCE_TESTNET=true          # true for testnet, false for mainnet

# Trading Symbol (USDS-M Futures use same symbols, just different settlement)
TRADING_SYMBOL=SOLUSDT        # Same as USDT-M

# Leverage (1-20x, but check USDS-M limits for your symbol)
TRADING_LEVERAGE=5.0

# Risk Management - IMPORTANT for USDS-M
MAX_DAILY_LOSS_PCT=0.05       # 5% daily loss limit
MAX_DRAWDOWN_PCT=0.10         # 10% max drawdown
MAX_POSITION_PCT=0.30         # Max 30% of account per position
KELLY_FRACTION=0.25           # Conservative Kelly Criterion

# Order Sizing
MIN_ORDER_QTY=0.1             # Minimum trade size (in base asset)
MAX_ORDER_QTY=1000.0          # Maximum trade size

# Strategy Parameters
BB_PERIOD=20                  # Bollinger Bands period
BB_STD_DEV=2.0
BB_ENTRY_THRESHOLD=0.5        # Entry within 0.5σ of lower band
EMA_FAST_PERIOD=50
EMA_SLOW_PERIOD=400
ADX_PERIOD=14
ADX_THRESHOLD=25.0
VOLUME_MULTIPLIER=1.2         # 1.2x average volume

# Live Trading Mode
LIVE_MODE=paper               # paper or live (START WITH PAPER)