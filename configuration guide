## Verification Script

After configuring, verify your setup with this Python script:

```python
#!/usr/bin/env python3
import sys
sys.path.insert(0, '.')
from core import Config

def verify_config():
    cfg = Config()
    
    print("=== Configuration Verification ===\n")
    
    # Binance Config
    print("Binance Configuration:")
    print(f"  Network: {'TESTNET' if cfg.binance.testnet else 'MAINNET'}")
    print(f"  Base URL: {cfg.binance.base_url}")
    print(f"  API Key: {cfg.binance.api_key[:10]}...***")
    print()
    
    # Trading Config
    print("Trading Configuration:")
    print(f"  Symbol: {cfg.trading.symbol}")
    print(f"  Leverage: {cfg.trading.leverage}x")
    print(f"  Max Position: {cfg.trading.max_position_pct:.0%} of equity")
    print(f"  Daily Loss Limit: {cfg.trading.max_daily_loss_pct:.0%}")
    print(f"  Drawdown Limit: {cfg.trading.max_drawdown_pct:.0%}")
    print(f"  Kelly Fraction: {cfg.trading.kelly_fraction:.0%}")
    print(f"  Min Order: {cfg.trading.min_order_qty} {cfg.trading.symbol}")
    print()
    
    # Strategy Config
    print("Strategy Configuration:")
    print(f"  Bollinger Bands Period: {cfg.strategy.bb_period}")
    print(f"  EMA Fast/Slow: {cfg.strategy.ema_fast_period}/{cfg.strategy.ema_slow_period}")
    print(f"  ADX Threshold: {cfg.strategy.adx_threshold}")
    print()
    
    # Live Trading Config
    print("Live Trading Configuration:")
    print(f"  Mode: {cfg.live.mode.upper()}")
    print()
    
    # Validation
    print("=== Validation ===")
    errors = []
    warnings = []
    
    # Check API keys
    if not cfg.binance.api_key or len(cfg.binance.api_key) < 30:
        errors.append("❌ BINANCE_API_KEY is missing or too short")
    else:
        print("✅ API credentials configured")
    
    # Check leverage
    if not 1.0 <= cfg.trading.leverage <= 20.0:
        errors.append(f"❌ Leverage {cfg.trading.leverage} outside 1-20 range")
    else:
        print(f"✅ Leverage {cfg.trading.leverage}x is valid")
    
    # Check risk limits
    if cfg.trading.max_daily_loss_pct > 0.20:
        warnings.append(f"⚠️  Daily loss limit {cfg.trading.max_daily_loss_pct:.0%} is high (>20%)")
    if cfg.trading.max_drawdown_pct > 0.30:
        warnings.append(f"⚠️  Drawdown limit {cfg.trading.max_drawdown_pct:.0%} is high (>30%)")
    if cfg.trading.max_position_pct > 0.50:
        warnings.append(f"⚠️  Max position {cfg.trading.max_position_pct:.0%} is high (>50%)")
    
    # Check Kelly fraction
    if cfg.trading.kelly_fraction > 0.50:
        warnings.append(f"⚠️  Kelly fraction {cfg.trading.kelly_fraction:.0%} is aggressive (>50%)")
    
    if not errors and not warnings:
        print("✅ Risk parameters are reasonable")
    
    if errors:
        print("\n❌ ERRORS:")
        for e in errors:
            print(f"  {e}")
        return False
    
    if warnings:
        print("\n⚠️  WARNINGS:")
        for w in warnings:
            print(f"  {w}")
    
    print("\n✅ Configuration is valid!")
    return True

if __name__ == "__main__":
    success = verify_config()
    sys.exit(0 if success else 1)
```

**Run it:**
```bash
python verify_config.py
```

